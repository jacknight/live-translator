# =============================================================================
# Live Translator Companion – Environment Configuration
# =============================================================================
# Copy this to .env and edit for your setup:
#   cp .env.example .env
#
# NOTE: whisper.cpp can be auto-installed via npm scripts
# (see package.json "postinstall" and setup docs).
# =============================================================================

# --- Whisper.cpp ------------------------------------------------------------
# Paths to your whisper.cpp build. If you ran `npm run setup-whisper`,
# these default to ./node_modules/.whisper/ (installed as an npm-managed dep).
# You can also point this at a system-wide install or another location.
LT_WHISPER_EXEC=./node_modules/.whisper/main
LT_WHISPER_MODEL=./node_modules/.whisper/models/ggml-base.en.bin

# Optional: auto-download a different model size on setup
# tiny / tiny.en / base / base.en / small / small.en / medium / medium.en / large
LT_WHISPER_MODEL_SIZE=base.en

# --- Translation ------------------------------------------------------------
# Source language (auto = auto-detect)
LT_SOURCE_LANG=auto
# Target language for translation
LT_TARGET_LANG=en
# Translation backend: null | libretranslate | deepl | google
LT_TRANSLATOR_BACKEND=null
# API URL for LibreTranslate (default local Docker instance)
LT_TRANSLATOR_API_URL=http://127.0.0.1:5000
# API key for DeepL or Google Cloud Translation
LT_TRANSLATOR_API_KEY=

# --- WebSocket Server -------------------------------------------------------
LT_WS_PORT=9876

# --- Logging ----------------------------------------------------------------
# debug | info | warn | error
LT_LOG_LEVEL=info
